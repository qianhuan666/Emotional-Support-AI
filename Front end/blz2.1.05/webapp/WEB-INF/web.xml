<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <context-param>
        <param-name>app.db.url</param-name>
        <param-value>jdbc:mysql://127.0.0.1:3306/jspdemo?useSSL=false&amp;sslMode=DISABLED&amp;allowPublicKeyRetrieval=true&amp;serverTimezone=Asia/Shanghai&amp;characterEncoding=UTF-8</param-value>
    </context-param>
    <context-param>
        <param-name>app.db.user</param-name>
        <param-value>root</param-value>
    </context-param>
    <context-param>
        <param-name>app.db.password</param-name>
        <param-value>asuka123</param-value>
    </context-param>
    <context-param>
        <param-name>app.ai.endpoint</param-name>
        <param-value>https://api.openai.com/v1/chat/completions</param-value>
    </context-param>
    <context-param>
        <param-name>app.ai.model</param-name>
        <param-value>gpt-4o-mini</param-value>
    </context-param>
    <context-param>
        <param-name>app.ai.key</param-name>
        <param-value></param-value>
